[Unit]
Description=Adam API Server - OpenAI compatible endpoint
After=network.target adam.service

[Service]
Type=simple
User=semn1
WorkingDirectory=/home/semn1/origin
EnvironmentFile=/home/semn1/origin/.env
ExecStart=/usr/bin/python3 /home/semn1/origin/adam_api.py
Restart=always
RestartSec=10
StandardOutput=append:/home/semn1/origin/adam_api.log
StandardError=append:/home/semn1/origin/adam_api.log

[Install]
WantedBy=multi-user.target
